# ── Block PHP execution ───────────────────────────────────────────────────────
# This site is a React SPA — no PHP should ever execute.
<FilesMatch "\.php$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType text/css .css
  AddType application/json .json
</IfModule>

# ── Caching strategy ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico|woff|woff2|ttf)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ── www → non-www canonical redirect ───────────────────────────────────────
  RewriteCond %{HTTP_HOST} ^www\.contentedly\.ai [NC]
  RewriteRule ^(.*)$ https://contentedly.ai/$1 [R=301,L]

  # ── Remove trailing slashes (except root) ──────────────────────────────────
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)/$ /$1 [R=301,L]

  # ── SPA routing: serve index.html for all non-file, non-dir requests ────────
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  RewriteRule ^ index.html [L]
</IfModule>
